# Copier ce fichier en .env et remplir les valeurs avant de démarrer

# Django
SECRET_KEY=changez-cette-valeur-par-une-cle-secrete-longue-et-aleatoire
DEBUG=False
ALLOWED_HOSTS=votre-ip-ou-domaine.com,www.votre-domaine.com

# URL Admin (choisir une URL secrète difficile à deviner)
ADMIN_URL=mon-panneau-secret-2024/

# Base de données PostgreSQL
DATABASE_URL=postgresql://otci_user:mot_de_passe_fort@localhost:5432/otci_db

# Ou en détail :
DB_NAME=otci_db
DB_USER=otci_user
DB_PASSWORD=mot_de_passe_fort
DB_HOST=localhost
DB_PORT=5432

# Cache (laisser vide pour utiliser le cache fichier en dev, mettre redis:// en prod)
CACHE_URL=redis://localhost:6379/1
